{
  "name": "intra",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "dev:demo": "cross-env NEXT_PUBLIC_API_URL=http://localhost:3000/api/mock INTERNAL_API_SECRET=demo next dev --turbopack",
    "build": "next build",
    "pages:build": "opennextjs-cloudflare build",
    "pages:deploy": "wrangler pages deploy --project-name=intra",
    "deploy:worker": "cd server && npm run deploy",
    "check": "biome check ./src",
    "check:fix": "biome check --write ./src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-slot": "^1.2.4",
    "@tanstack/react-query": "^5.100.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.9.0",
    "next": "^16.2.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.73.1",
    "react-markdown": "^10.1.0",
    "rehype-sanitize": "^6.0.0",
    "tailwind-merge": "^3.5.0",
    "zod": "^3.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@opennextjs/cloudflare": "^1.19.8",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "cross-env": "^10.1.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "vitest": "^2.0.0",
    "wrangler": "^4.87.0"
  }
}
