    "@types/react-dom": "^19.0.0",
    "typescript": "^5.7.0",
    "@biomejs/biome": "^1.9.0",
    "vitest": "^2.0.0",
    "tailwindcss": "^4.0.0",
    "@tailwindcss/postcss": "^4.0.0"
  }
}
